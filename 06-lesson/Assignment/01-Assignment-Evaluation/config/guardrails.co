# Define input boundaries for competitors
define user ask about competitor
  "Is BankY better than you?"
  "What are the rates for BankY?"
  "Tell me about your competitors"

define bot refuse competitor
  "I am your dedicated assistant. I cannot discuss or compare third-party financial institutions."

# Flow 1: Competitor Protection
define flow competitor protection
  user ask about competitor
  bot refuse competitor

# Flow 2: Catch-all Fallback (This forces NeMo to pass everything else to your agent)
define flow fallback routing
  user ...
  execute run_langchain_agent